    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: CRSA",
            "type": "debugpy",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "module": "crsa.scripts.parameters",
