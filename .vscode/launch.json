{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: CRSA",
            "type": "debugpy",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "module": "crsa.scripts.parameters",
            "args": [
                "--world", "findA1_simple",
                "--pasts", "1st 2nd",
                "--alphas", "2.0",
                "--max_depths", "4",
                "-v"
            ]
        },
        {
            "name": "Debug: models",
            "type": "debugpy",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "module": "crsa.scripts.compare_models",
            "args": [
                "--world", "findA1",
                "--models", "crsa_sample", "crsa_max",
                "--n_turns", "3",
                "--alpha", "2.0",
                "--max_depth", "4",
                "--seed", "12345",
                "--n_seeds", "2",
                "--verbose",
            ]
        }
    ]
}