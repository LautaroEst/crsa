{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: CRSA",
            "type": "debugpy",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "module": "crsa.scripts.parameters",
            "args": [
                "--world", "findA1_simple",
                "--pasts", "1st 2nd",
                "--alphas", "2.0",
                "--max_depths", "10",
                "-v"
            ]
        },
        {
            "name": "Debug: models",
            "type": "debugpy",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "module": "crsa.scripts.run_findA1",
            "args": [
                "--n_possitions", "3",
                "--models", "crsa", "memoryless_rsa", "memoryless_literal", "prior_model",
                "--n_turns", "9",
                "--alpha", "2.0",
                "--tolerance", "1e-3",
                "--seed", "1234",
                "--n_seeds", "10"
            ]
        },
        {
            "name": "Debug: infojigsaw",
            "type": "debugpy",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "module": "crsa.scripts.run_infojigsaw",
            "args": [
                "--models", "literal", "multi_rsa", "crsa",
                "--alpha", "2.0",
                "--tolerance", "1e-3",
                "--seed", "12345",
            ]    
        }
    ]
}